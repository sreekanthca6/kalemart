{
  "title": "Kalemart — API Latency",
  "uid": "kalemart-api-latency",
  "tags": ["kalemart"],
  "timezone": "browser",
  "schemaVersion": 38,
  "refresh": "15s",
  "panels": [
    {
      "id": 1,
      "title": "Request Rate (rps)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{
        "expr": "sum(rate(kalemart_http_requests_total[1m])) by (route)",
        "legendFormat": "{{route}}"
      }]
    },
    {
      "id": 2,
      "title": "P50 / P95 / P99 Latency (ms)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(kalemart_http_request_duration_ms_milliseconds_bucket[5m])) by (le))",
          "legendFormat": "P50"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(kalemart_http_request_duration_ms_milliseconds_bucket[5m])) by (le))",
          "legendFormat": "P95"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(kalemart_http_request_duration_ms_milliseconds_bucket[5m])) by (le))",
          "legendFormat": "P99"
        }
      ]
    },
    {
      "id": 3,
      "title": "Error Rate (%)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "red" }
        }
      },
      "targets": [{
        "expr": "100 * (sum(rate(kalemart_http_errors_total[1m])) or vector(0)) / clamp_min(sum(rate(kalemart_http_requests_total[1m])), 1)",
        "legendFormat": "Error %"
      }]
    },
    {
      "id": 4,
      "title": "Active Traces",
      "type": "table",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "datasource": { "type": "tempo", "uid": "tempo" },
      "targets": [{
        "queryType": "nativeSearch",
        "serviceName": "kalemart-backend",
        "limit": 20
      }]
    }
  ]
}
