{
  "title": "Kalemart — AI Service",
  "uid": "kalemart-ai",
  "tags": ["kalemart", "ai"],
  "timezone": "browser",
  "schemaVersion": 38,
  "refresh": "30s",
  "panels": [
    {
      "id": 1,
      "title": "Insight Requests / min",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{
        "expr": "sum(rate(kalemart_ai_http_requests_total[1m])) * 60",
        "legendFormat": "Requests/min"
      }]
    },
    {
      "id": 2,
      "title": "AI Service Latency P95 (ms)",
      "type": "gauge",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 3000 },
              { "color": "red", "value": 8000 }
            ]
          },
          "unit": "ms",
          "min": 0,
          "max": 15000
        }
      },
      "targets": [{
        "expr": "histogram_quantile(0.95, sum(rate(kalemart_ai_http_request_duration_ms_milliseconds_bucket[5m])) by (le))",
        "legendFormat": "P95"
      }]
    },
    {
      "id": 3,
      "title": "AI 5xx Errors / min",
      "type": "stat",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{
        "expr": "(sum(rate(kalemart_ai_http_requests_total{status_class=\"5xx\"}[1m])) or vector(0)) * 60",
        "legendFormat": "5xx/min"
      }]
    },
    {
      "id": 4,
      "title": "AI Traffic by Route",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 8, "w": 24, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{
        "expr": "sum by (route, status_class) (rate(kalemart_ai_http_requests_total[5m]))",
        "legendFormat": "{{route}} {{status_class}}"
      }]
    },
    {
      "id": 5,
      "title": "AI observability note",
      "type": "text",
      "gridPos": { "x": 0, "y": 16, "w": 24, "h": 8 },
      "options": {
        "mode": "markdown",
        "content": "This local dashboard intentionally uses Prometheus metrics that are confirmed to exist. Tempo is wired separately for traces, but this panel avoids showing an empty trace search when no AI trace traffic has been generated."
      }
    }
  ]
}
